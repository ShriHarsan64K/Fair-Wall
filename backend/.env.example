# ── Google Cloud ───────────────────────────────────────────────────────────────
GCP_PROJECT=fairwall-2026
BQ_DATASET=fairwall_logs
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Gemma / Ollama ─────────────────────────────────────────────────────────────
# Options: ollama | vertex
GEMMA_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Swap ladder — tried in order if previous fails due to OOM or unavailability
# gemma4:e4b  → primary   (6GB VRAM — best quality)
# gemma4:e2b  → fallback1 (3GB VRAM — slightly smaller)
# gemma3:4b   → fallback2 (3GB VRAM — proven stable)
GEMMA_MODEL_PRIMARY=gemma4:e4b
GEMMA_MODEL_FALLBACK1=gemma4:e2b
GEMMA_MODEL_FALLBACK2=gemma3:4b

# Vertex AI (only needed when GEMMA_BACKEND=vertex)
VERTEX_REGION=us-central1
VERTEX_ENDPOINT_ID=

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
