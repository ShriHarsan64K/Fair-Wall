# ═══════════════════════════════════════════════════════════════
# FairWall — .gitignore
# Covers: Python backend + React/TypeScript/Bun frontend + GCP
# ═══════════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── ML model files ──────────────────────────────────────────────
*.pkl
*.pickle
*.model

# ── Secrets / Environment ───────────────────────────────────────
.env
backend/.env
.env.local
.env.*.local

# ── GCP Keys (NEVER commit these) ───────────────────────────────
service-account.json
*-service-account.json
*.json.key
gcp-key.json
application_default_credentials.json

# ── Google Cloud / Firebase ─────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log

# ── Node / Bun / Frontend ───────────────────────────────────────
node_modules/
dist/
dist-ssr/
.output/
.vinxi/
.tanstack/
.nitro/
*.tsbuildinfo

# ── Wrangler / Cloudflare (Lovable template — not used) ─────────
.wrangler/
.dev.vars
wrangler.jsonc

# ── Demo generated data ─────────────────────────────────────────
demo/*.csv

# ── OS files ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ──────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~

# ── Logs ────────────────────────────────────────────────────────
*.log
logs/